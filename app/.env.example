DATABASE_URL=postgres://iot_bee:iot_bee_dev@127.0.0.1:5432/iot_bee
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/%2f

# HTTP server
API_HOST=127.0.0.1
API_PORT=8080

# Logging
RUST_LOG=info

# Auth
JWT_SECRET=change-me-in-production-this-must-be-long-and-random
JWT_EXPIRES_IN_HOURS=24
CORS_ORIGINS=http://localhost:3000

# Stripe test checkout
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SYNC_SECRET=change-me-local-stripe-sync-secret

# Long-lived admin JWT used by the Next.js stripe webhook to call /license/stripe-sync.
# Issue via: POST /auth/login as admin, then copy the token.
SERVICE_ADMIN_TOKEN=

# Set to 1 to expose /swagger-ui/ (dev only). Off in prod.
SWAGGER_ENABLED=0

# Días que se conservan los audit_events antes de ser purgados por el cron interno.
AUDIT_RETENTION_DAYS=90

# Transactional emails (Resend). Leave RESEND_API_KEY blank to fall back to
# the LogNotifier, which only logs the message instead of sending it.
RESEND_API_KEY=
EMAIL_FROM="iot bees <hello@iotbees.dev>"
EMAIL_REPLY_TO=support@iotbees.dev
