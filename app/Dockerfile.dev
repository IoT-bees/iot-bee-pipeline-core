FROM rust:1-slim-bookworm

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        pkg-config \
        libssl-dev \
        libpq-dev \
        ca-certificates \
        curl \
    && rm -rf /var/lib/apt/lists/*

RUN cargo install cargo-watch --locked

WORKDIR /app

ENV API_HOST=0.0.0.0 \
    API_PORT=8080 \
    RUST_LOG=info

EXPOSE 8080

CMD ["cargo", "watch", "-x", "run"]
