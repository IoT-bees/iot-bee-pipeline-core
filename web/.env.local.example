# Solo servidor: nunca se publica al navegador. En Vercel debe ser la URL
# HTTPS pública del backend, sin barra final (por ejemplo https://api.example.com).
BACKEND_API_URL=http://localhost:8080
# Tiempo máximo de una llamada BFF al backend.
BACKEND_API_TIMEOUT_MS=10000
# URL publica canonica. En Vercel usa el dominio de produccion, sin barra final.
NEXT_PUBLIC_SITE_URL=https://example.com
AUTH_COOKIE_NAME=iot_bee_session
AUTH_COOKIE_MAX_AGE_HOURS=24
# 1 para HTTPS (producción/staging), 0 solo para desarrollo HTTP local.
AUTH_COOKIE_SECURE=0

# Stripe test checkout
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SYNC_SECRET=change-me-local-stripe-sync-secret
# Token de servicio usado exclusivamente por la ruta server-side de sincronía.
SERVICE_ADMIN_TOKEN=
